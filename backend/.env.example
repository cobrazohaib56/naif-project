# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3001

# Frontend (for CORS + password reset links)
FRONTEND_URL=http://localhost:5173

# AI provider selection: "groq" (default) or "gemini"
LLM_PROVIDER=groq

# AI - GROQ (primary LLM)
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# AI - Gemini (fallback LLM — set LLM_PROVIDER=gemini to use)
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash-lite

# Embedding provider for RAG (jina | huggingface). Default: jina
EMBEDDING_PROVIDER=jina

# AI - Jina (primary embeddings — required for Ask AI)
# Get a free key at https://jina.ai (10M free tokens on signup, no credit card)
JINA_API_KEY=your-jina-api-key
# JINA_EMBEDDING_MODEL=jina-embeddings-v3

# AI - HuggingFace (fallback embeddings — set EMBEDDING_PROVIDER=huggingface to use)
HUGGINGFACE_API_KEY=your-huggingface-api-key
# HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Email - Gmail SMTP (required for forgot-password and welcome emails)
# Gmail requires an App Password — see https://support.google.com/accounts/answer/185833
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
