# ── Database (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Auth (required) ────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=paste-generated-secret-here
# Local dev: keep as-is. Production: set to your deployed backend URL.
NEXTAUTH_URL=http://localhost:3001
# Local dev: keep as-is. Production: set to your deployed frontend URL.
FRONTEND_URL=http://localhost:5173

# ── LLM provider (required for all AI features) ────────────────────────────────
# "groq" (default, free) or "gemini"
LLM_PROVIDER=groq

# GROQ — free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini — only needed if LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash-lite

# ── Embedding provider (required for Ask AI document indexing) ─────────────────
# "jina" (default, free) or "huggingface"
EMBEDDING_PROVIDER=jina

# Jina AI — free key at https://jina.ai (10M free tokens, no credit card)
JINA_API_KEY=jina_...
# JINA_EMBEDDING_MODEL=jina-embeddings-v3

# HuggingFace — only needed if EMBEDDING_PROVIDER=huggingface
# HUGGINGFACE_API_KEY=hf_...
# HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Email / SMTP (optional — only for forgot-password emails) ──────────────────
# Gmail requires an App Password: https://support.google.com/accounts/answer/185833
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
